alert http any any -> $HOME_NET any (msg:"BACHSIEM SQL SQLMap User-Agent"; flow:to_server,established; http.user_agent; content:"sqlmap"; nocase; classtype:web-application-attack; sid:9000001; rev:1;)
alert http any any -> $HOME_NET any (msg:"BACHSIEM SQL UNION SELECT"; flow:to_server,established; http.uri; pcre:"/(\%27|\')\s*UNION\s+SELECT/i"; classtype:web-application-attack; sid:9000002; rev:1;)
alert http any any -> $HOME_NET 8080 (msg:"BACHSIEM Drupalgeddon CVE-2014-3704"; flow:to_server,established; http.uri; content:"/?q=node"; http.request_body; content:"name[0%20;"; nocase; classtype:web-application-attack; sid:9000003; rev:1;)
